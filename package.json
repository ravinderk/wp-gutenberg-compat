{
    "name": "wp-gutenberg-compat",
    "version": "0.0.0",
    "private": true,
    "description": "Toolchain to verify @wordpress/* package compatibility with minimum WordPress versions",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "generate": "node scripts/generate.js",
        "test": "npm test --workspaces --if-present",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "engines": {
        "node": ">=18"
    },
    "license": "MIT",
    "devDependencies": {
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1"
    }
}

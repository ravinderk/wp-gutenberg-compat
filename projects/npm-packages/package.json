{
    "name": "@ravi.nder/wp-gutenberg-compat",
    "version": "0.5.0",
    "description": "CLI tool to verify @wordpress/* packages are compatible with your plugin's minimum supported WordPress version",
    "bin": {
        "wp-gutenberg-compat": "./dist/cli.js"
    },
    "files": [
        "dist",
        "CHANGELOG.md"
    ],
    "scripts": {
        "dev:cli": "tsx src/cli.ts",
        "build": "tsc && node scripts/copy-data.js",
        "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
        "generate": "tsx scripts/generate.ts",
        "test": "vitest run",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "wordpress",
        "gutenberg",
        "compatibility",
        "cli"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ravinderk/wp-gutenberg-compat.git",
        "directory": "projects/npm-packages"
    },
    "devDependencies": {
        "@types/node": "^22.19.15",
        "@types/semver": "^7.7.1",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "semver": "^7.7.4"
    }
}

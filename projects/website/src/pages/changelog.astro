---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const changelogPath = resolve(process.cwd(), '../npm-packages/CHANGELOG.md');
const raw = readFileSync(changelogPath, 'utf-8');

// Parse the changelog markdown into structured data
const sections: { version: string; date: string; categories: { name: string; items: string[] }[] }[] = [];
let current: (typeof sections)[0] | null = null;
let currentCategory: { name: string; items: string[] } | null = null;

for (const line of raw.split('\n')) {
    const versionMatch = line.match(/^## \[(.+?)\] - (\d{4}-\d{2}-\d{2})/);
    if (versionMatch) {
        current = { version: versionMatch[1], date: versionMatch[2], categories: [] };
        sections.push(current);
        currentCategory = null;
        continue;
    }

    const categoryMatch = line.match(/^### (.+)/);
    if (categoryMatch && current) {
        currentCategory = { name: categoryMatch[1], items: [] };
        current.categories.push(currentCategory);
        continue;
    }

    const itemMatch = line.match(/^- (.+)/);
    if (itemMatch && currentCategory) {
        currentCategory.items.push(itemMatch[1]);
    }
}

function formatDate(iso: string) {
    const [year, month, day] = iso.split('-').map(Number);
    return new Date(year, month - 1, day).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function categoryColor(name: string) {
    switch (name) {
        case 'Added': return 'text-[var(--color-green)]';
        case 'Changed': return 'text-[var(--color-yellow)]';
        case 'Fixed': return 'text-[var(--color-red)]';
        default: return 'text-[var(--color-muted)]';
    }
}

function categoryBadgeBg(name: string) {
    switch (name) {
        case 'Added': return 'bg-green-50 border-green-200';
        case 'Changed': return 'bg-amber-50 border-amber-200';
        case 'Fixed': return 'bg-red-50 border-red-200';
        default: return 'bg-gray-50 border-gray-200';
    }
}

function categoryIcon(name: string) {
    switch (name) {
        case 'Added': return '＋';
        case 'Changed': return '↻';
        case 'Fixed': return '✓';
        default: return '·';
    }
}

---

<Layout title="Changelog — wp-gutenberg-compat" description="Release history for wp-gutenberg-compat CLI tool.">
    <Nav />
    <main class="pt-24 pb-16 px-6">
        <div class="mx-auto max-w-3xl">
            <div class="flex items-center gap-3 flex-wrap">
                <h1 class="text-3xl font-bold tracking-tight text-[var(--color-text)]">Changelog</h1>
                {sections[0] && (
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-[var(--color-accent)] text-white text-xs font-medium">
                        Latest: v{sections[0].version}
                    </span>
                )}
            </div>
            <p class="mt-2 text-[var(--color-muted)] text-sm">
                All notable changes to the
                <a href="https://www.npmjs.com/package/@ravi.nder/wp-gutenberg-compat" class="underline hover:text-[var(--color-text)] transition-colors">npm package</a>.
            </p>
            <div class="mt-10 space-y-12">
                {sections.map((section, idx) => (
                    <article class="relative pl-6 border-l-2 border-[var(--color-border)]">
                        <div class={`absolute -left-[7px] top-1 w-3 h-3 rounded-full border-2 border-white ${idx === 0 ? 'bg-[var(--color-accent)]' : 'bg-[var(--color-border)]'}`} />
                        <div class="flex items-baseline gap-3 flex-wrap">
                            <h2 class="text-lg font-semibold text-[var(--color-text)]">v{section.version}</h2>
                            {idx === 0 && (
                                <span class="text-xs font-medium px-1.5 py-0.5 rounded bg-[var(--color-accent)] text-white leading-none">Latest</span>
                            )}
                            <time class="text-xs text-[var(--color-muted)] tabular-nums">{formatDate(section.date)}</time>
                        </div>

                        <div class="mt-4 space-y-4">
                            {section.categories.map((cat) => (
                                <div>
                                    <span class={`inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full border ${categoryBadgeBg(cat.name)} ${categoryColor(cat.name)}`}>
                                        <span aria-hidden="true">{categoryIcon(cat.name)}</span>
                                        {cat.name}
                                    </span>
                                    <ul class="mt-2 space-y-1.5">
                                        {cat.items.map((item) => (
                                            <li class="text-sm text-[var(--color-text)] leading-relaxed flex gap-2">
                                                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-border)] shrink-0" />
                                                <span set:html={item.replace(/`([^`]+)`/g, '<code class="text-xs px-1 py-0.5 rounded bg-[var(--color-surface)] font-mono">$1</code>')} />
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            ))}
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </main>
    <Footer />
</Layout>

---
---

<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 overflow-hidden">
    <!-- Grid background -->
    <div class="absolute inset-0 grid-bg opacity-30"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-8 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs text-[var(--color-muted)]">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green)] animate-pulse"></span>
            Works with WordPress 5.8 – 6.8
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl text-[var(--color-text)] leading-[1.05] tracking-[-0.05em] mb-6 font-normal">
            Stop shipping
            <em class="not-italic text-[var(--color-accent)] glow-text"> broken blocks</em>
            <br />to older WordPress sites
        </h1>

        <!-- Sub -->
        <p class="max-w-2xl mx-auto text-lg text-[var(--color-muted)] leading-relaxed mb-10">
            Gutenberg packages update faster than WordPress core ships them.
            Your blocks should work on every WordPress version you support — not just the latest one.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
            <a
                href="#install"
                class="px-6 py-3 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-muted)] text-white font-medium text-sm transition-all"
            >
                Get started  →
            </a>
            <a
                href="#how-it-works"
                class="px-6 py-3 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-subtle)] text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-all"
            >
                See how it works →
            </a>
        </div>

        <!-- Hero terminal -->
        <div class="mx-auto max-w-2xl rounded-xl overflow-hidden shadow-2xl text-left glow-border bg-[var(--color-surface-dark)]">
            <!-- Terminal chrome -->
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/10 bg-black/30">
                <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
                <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
                <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
                <span class="ml-4 text-xs text-white/40 font-[family-name:var(--font-mono)]">terminal</span>
            </div>
            <!-- Terminal body -->
            <div class="p-5 font-[family-name:var(--font-mono)] text-sm leading-7 space-y-1">
                <p class="terminal-prompt text-white/90">npx @ravi.nder/wp-gutenberg-compat@latest analyze</p>
                <p class="text-white/30">&nbsp;</p>
                <p class="text-white/90">Detected minimum WP version: <span class="text-amber-400">6.5</span></p>
                <p class="text-white/50">Scanning @wordpress/* packages...</p>
                <p class="text-white/30">&nbsp;</p>
                <p class="text-red-400">✗ @wordpress/block-editor  installed: 14.2.0  compat: 12.9.0</p>
                <p class="text-red-400">✗ @wordpress/data          installed: 10.7.0  compat: 9.28.0</p>
                <p class="text-white/30">&nbsp;</p>
                <p class="text-amber-400">2 incompatible packages found. Run `install` to fix.</p>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--color-muted)] animate-bounce">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>
</section>

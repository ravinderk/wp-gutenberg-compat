---
const features = [
    {
        icon: `<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
        color: 'var(--color-accent)',
        title: 'Automatic detection',
        desc: 'Reads your plugin header or style.css to find the declared minimum WordPress version — no configuration required.',
    },
    {
        icon: `<path d="M9 3H5a2 2 0 00-2 2v4m6-6h6a2 2 0 012 2v4M9 3v10m0 0h6m-6 0H3m6 0v4m6-4v4m0-4h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
        color: 'var(--color-green)',
        title: 'Version mapping',
        desc: 'Cross-references each \`@wordpress/*\` package against the exact versions bundled with every WordPress release.',
    },
    {
        icon: `<path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
        color: 'var(--color-yellow)',
        title: 'One-command fix',
        desc: 'Automatically downgrades incompatible packages to the correct versions so your IDE IntelliSense only shows APIs that exist in your minimum WP version.',
    },
    {
        icon: `<path d="M8 9l3 3-3 3m5 0h3M3 4h18M3 8h18M3 12h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
        color: '#a78bfa',
        title: 'CI-friendly',
        desc: 'Exits with a non-zero code when mismatches are found, so you can gate PRs from merging with incompatible packages.',
    },
];
---

<section id="features" class="py-28 px-6 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl">
        <!-- Section header -->
        <div class="mb-16 text-center">
            <p class="text-xs uppercase tracking-widest text-[var(--color-accent)] font-[family-name:var(--font-mono)] mb-4">Features</p>
            <h2 class="text-4xl md:text-5xl text-[var(--color-text)] tracking-[-0.04em] font-normal">
                Everything you need to ship<br /><em class="not-italic text-[var(--color-muted)]">with confidence</em>
            </h2>
        </div>

        <!-- Feature grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-[var(--color-border)]">
            {features.map((f) => (
                <div class="bg-[var(--color-bg)] p-8 flex flex-col gap-5 hover:bg-[var(--color-surface)] transition-colors group">
                    <div
                        class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
                        style={`background: color-mix(in srgb, ${f.color} 12%, transparent); border: 1px solid color-mix(in srgb, ${f.color} 25%, transparent);`}
                    >
                        <svg width="18" height="18" viewBox="0 0 24 24" set:html={f.icon} style={`color: ${f.color}; --icon-color: ${f.color};`}/>
                    </div>
                    <div>
                        <h3 class="text-base font-semibold text-[var(--color-text)] mb-2">{f.title}</h3>
                        <p class="text-sm text-[var(--color-muted)] leading-relaxed">{f.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-white/90 backdrop-blur-sm">
    <div class="mx-auto max-w-6xl px-6 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-7 h-7 rounded-lg bg-[var(--color-accent)] flex items-center justify-center">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 4h12M2 8h8M2 12h5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="text-sm font-semibold text-[var(--color-text)]">wp-gutenberg-compat</span>
        </a>

        <nav class="flex items-center gap-1">
            <a href="/#features" class="px-3 py-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Features</a>
            <a href="/#how-it-works" class="px-3 py-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">How it works</a>
            <a href="/#install" class="px-3 py-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Install</a>
            <a href="/changelog" class="px-3 py-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Changelog</a>
            <a
                href="https://github.com/ravinderk/wp-gutenberg-compat"
                target="_blank"
                rel="noopener noreferrer"

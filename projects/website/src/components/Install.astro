---
const commands = [
    { cmd: 'npx @ravi.nder/wp-gutenberg-compat@latest analyze', desc: 'Analyze and report mismatches' },
    { cmd: 'npx @ravi.nder/wp-gutenberg-compat@latest install', desc: 'Auto-install compatible versions' },
    { cmd: 'npx @ravi.nder/wp-gutenberg-compat@latest info', desc: 'Show WP version → package mapping' },
];
---

<section id="install" class="py-28 px-6 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Left -->
            <div>
                <p class="text-xs uppercase tracking-widest text-[var(--color-accent)] font-[family-name:var(--font-mono)] mb-4">Get started</p>
                <h2 class="text-4xl md:text-5xl text-[var(--color-text)] tracking-[-0.04em] mb-6 font-normal">
                    No install<br />required
                </h2>
                <p class="text-[var(--color-muted)] leading-relaxed mb-8">
                    Run it ad-hoc with <code class="text-[var(--color-text)] bg-[var(--color-surface)] px-1.5 py-0.5 rounded text-sm font-[family-name:var(--font-mono)]">npx</code>,
                    or install it as a dev dependency for repeatable CI runs.
                </p>

                <div class="flex flex-col sm:flex-row gap-3">
                    <a
                        href="https://github.com/ravinderk/wp-gutenberg-compat"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-5 py-2.5 rounded-lg bg-[var(--color-accent)] hover:bg-[var(--color-accent-muted)] text-white font-medium text-sm transition-all text-center"
                    >
                        View on GitHub
                    </a>
                    <a
                        href="https://www.npmjs.com/package/@ravi.nder/wp-gutenberg-compat"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-5 py-2.5 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-subtle)] text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-all text-center"
                    >
                        View on npm →
                    </a>
                </div>
            </div>

            <!-- Right: Commands -->
            <div class="rounded-xl overflow-hidden shadow-2xl glow-border bg-[var(--color-surface-dark)]">
                <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/10 bg-black/30">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
                </div>

                <div class="divide-y divide-white/10">
                    {commands.map((c) => (
                        <div class="p-5 group flex items-start justify-between gap-4 hover:bg-white/5 transition-colors">
                            <div class="flex-1 min-w-0">
                                <p class="text-xs text-white/40 mb-1.5">{c.desc}</p>
                                <code class="font-[family-name:var(--font-mono)] text-sm text-white/90 break-all">
                                    <span class="text-green-400">$</span> {c.cmd}
                                </code>
                            </div>
                            <button
                                class="shrink-0 mt-4 p-1.5 rounded text-white/40 hover:text-white hover:bg-white/10 transition-all copy-btn"
                                data-copy={c.cmd}
                                aria-label="Copy command"
                            >
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                    <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
                                </svg>
                            </button>
                        </div>
                    ))}
                </div>

                <!-- Local install option -->
                <div class="p-5 border-t border-white/10 bg-black/20">
                    <p class="text-xs text-white/40 mb-1.5">Or install as dev dependency</p>
                    <code class="font-[family-name:var(--font-mono)] text-sm text-white/60">
                        <span class="text-green-400">$</span> npm install -D @ravi.nder/wp-gutenberg-compat
                    </code>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
            const text = btn.dataset.copy ?? '';
            await navigator.clipboard.writeText(text);
            btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            setTimeout(() => {
                btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>`;
            }, 1500);
        });
    });
</script>

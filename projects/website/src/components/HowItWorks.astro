---
const steps = [
    {
        num: '01',
        title: 'Reads your plugin header',
        desc: 'Scans your plugin\'s main PHP file or theme\'s style.css for the "Requires at least" field to determine the minimum WordPress version you\'ve declared.',
        code: `/*
 * Plugin Name: My Block Plugin
 * Requires at least: 6.5   ← reads this
 */`,
    },
    {
        num: '02',
        title: 'Compares installed packages',
        desc: 'Looks up the @wordpress/* packages installed in your node_modules and cross-references them against the exact package versions bundled with that WordPress release.',
        code: `@wordpress/block-editor
  installed:  14.2.0  (WordPress 6.8)
  required:   12.9.0  (WordPress 6.5)
  status:     ✗ incompatible`,
    },
    {
        num: '03',
        title: 'Installs the right versions',
        desc: 'One command downgrades all mismatched packages to the versions that ship with your minimum WordPress version. Your IDE now only knows about APIs that actually exist.',
        code: `$ npx wp-gutenberg-compat install
✓ Installing compatible versions...
✓ @wordpress/block-editor@12.9.0
✓ @wordpress/data@9.28.0
✓ Done. Your IDE is now version-accurate.`,
    },
];
---

<section id="how-it-works" class="py-28 px-6 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl">
        <!-- Section header -->
        <div class="mb-20 text-center">
            <p class="text-xs uppercase tracking-widest text-[var(--color-accent)] font-[family-name:var(--font-mono)] mb-4">How it works</p>
            <h2 class="text-4xl md:text-5xl text-[var(--color-text)] tracking-tight" style="font-family: var(--font-display);">
                Three steps to<br /><em class="not-italic text-[var(--color-muted)]">zero silent breakage</em>
            </h2>
        </div>

        <!-- Steps -->
        <div class="space-y-px">
            {steps.map((step, i) => (
                <div class={`grid grid-cols-1 lg:grid-cols-2 gap-px bg-[var(--color-border)] ${i % 2 === 1 ? '' : ''}`}>
                    <!-- Text side -->
                    <div class={`bg-[var(--color-bg)] p-10 flex gap-8 items-start ${i % 2 === 1 ? 'lg:order-last' : ''}`}>
                        <span class="text-5xl font-bold text-[var(--color-border)] font-[family-name:var(--font-mono)] shrink-0 leading-none">{step.num}</span>
                        <div>
                            <h3 class="text-xl font-semibold text-[var(--color-text)] mb-3">{step.title}</h3>
                            <p class="text-[var(--color-muted)] leading-relaxed">{step.desc}</p>
                        </div>
                    </div>
                    <!-- Code side -->
                    <div class={`bg-[var(--color-surface)] p-10 flex items-center ${i % 2 === 1 ? 'lg:order-first' : ''}`}>
                        <pre class="font-[family-name:var(--font-mono)] text-sm text-[var(--color-muted)] leading-7 whitespace-pre-wrap overflow-auto w-full"><code set:html={step.code.replace(/✓/g, '<span style="color: var(--color-green)">✓</span>').replace(/✗/g, '<span style="color: var(--color-red)">✗</span>').replace(/6\.5/g, '<span style="color: var(--color-yellow)">6.5</span>').replace(/14\.2\.0/g, '<span style="color: var(--color-red)">14.2.0</span>').replace(/12\.9\.0/g, '<span style="color: var(--color-green)">12.9.0</span>')}></code></pre>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
